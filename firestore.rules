rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isValidDate(value) {
      return value is string && value.matches('^\\d{4}-\\d{2}-\\d{2}$');
    }

    function isValidTime(value) {
      return value in ['08:00', '09:00', '10:00', '11:00', '12:00', '18:00', '19:00', '20:00'];
    }

    function isValidCity(value) {
      return value in ['Aparecida', 'Cachoeira Paulista', 'Canas', 'Guaratinguetá', 'Lorena', 'Potim'];
    }

    function isValidTravelFee(city, km, value) {
      return (
        city in ['Guaratinguetá', 'Lorena'] &&
        km == 0 &&
        value == 0
      ) || (
        city == 'Aparecida' &&
        km == 8 &&
        value == 20
      ) || (
        city == 'Canas' &&
        km == 22 &&
        value == 50
      ) || (
        city == 'Cachoeira Paulista' &&
        km == 27 &&
        value == 60
      ) || (
        city == 'Potim' &&
        km == 9 &&
        value == 20
      );
    }

    function isStringBetween(value, min, max) {
      return value is string && value.size() >= min && value.size() <= max;
    }

    function isOptionalString(value, max) {
      return value is string && value.size() <= max;
    }

    match /slots/{slotId} {
      allow read: if true;
      allow create: if isAdmin() || (
        !exists(/databases/$(database)/documents/slots/$(slotId)) &&
        request.resource.data.keys().hasOnly(['id', 'data', 'horario', 'status', 'createdAt', 'createdAtIso']) &&
        request.resource.data.id == slotId &&
        isValidDate(request.resource.data.data) &&
        isValidTime(request.resource.data.horario) &&
        request.resource.data.status == 'agendado' &&
        request.resource.data.createdAt == request.time &&
        request.resource.data.createdAtIso is string
      );
      allow update: if isAdmin();
      allow delete: if false;
    }

    match /agendamentos/{slotId} {
      allow read: if isAdmin();
      allow create: if isAdmin() || (
        !exists(/databases/$(database)/documents/agendamentos/$(slotId)) &&
        existsAfter(/databases/$(database)/documents/slots/$(slotId)) &&
        request.resource.data.keys().hasOnly([
          'id',
          'nome',
          'telefone',
          'whatsapp',
          'empresa',
          'rua',
          'numero',
          'bairro',
          'cidade',
          'modeloMaquina',
          'servico',
          'data',
          'horario',
          'observacoes',
          'deslocamentoKm',
          'deslocamentoValor',
          'status',
          'createdAt',
          'createdAtIso'
        ]) &&
        request.resource.data.id == slotId &&
        isValidDate(request.resource.data.data) &&
        isValidTime(request.resource.data.horario) &&
        request.resource.data.status == 'agendado' &&
        request.resource.data.createdAt == request.time &&
        isStringBetween(request.resource.data.nome, 3, 100) &&
        isStringBetween(request.resource.data.telefone, 8, 20) &&
        isStringBetween(request.resource.data.whatsapp, 8, 20) &&
        isStringBetween(request.resource.data.rua, 3, 120) &&
        isStringBetween(request.resource.data.numero, 1, 20) &&
        isStringBetween(request.resource.data.bairro, 2, 80) &&
        isValidCity(request.resource.data.cidade) &&
        isStringBetween(request.resource.data.servico, 3, 80) &&
        request.resource.data.deslocamentoKm is number &&
        request.resource.data.deslocamentoValor is number &&
        isValidTravelFee(
          request.resource.data.cidade,
          request.resource.data.deslocamentoKm,
          request.resource.data.deslocamentoValor
        ) &&
        isOptionalString(request.resource.data.empresa, 120) &&
        isOptionalString(request.resource.data.modeloMaquina, 120) &&
        isOptionalString(request.resource.data.observacoes, 800) &&
        request.resource.data.createdAtIso is string
      );
      allow update: if isAdmin();
      allow delete: if false;
    }

    match /clientes/{clienteId} {
      allow read, create, update: if isAdmin();
      allow delete: if false;
    }

    match /servicos/{servicoId} {
      allow read, create, update: if isAdmin();
      allow delete: if false;
    }

    match /gastos/{gastoId} {
      allow read, create, update: if isAdmin();
      allow delete: if false;
    }

    function isAdmin() {
      return request.auth != null &&
        request.auth.token.email in ['wilds.campos@laserfix.app', 'wilds.mc@gmail.com'];
    }
  }
}
